generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model Obra {
  id               String   @id
  slug             String   @unique
  nombre           String
  titulo           String?
  tipo             String?
  categoria        String?
  direccion        String?
  ubicacion        String?
  anio             String?
  estado           String   @default("finalizada")
  avance           Int      @default(100)
  descripcion      String   @default("")
  proceso          String   @default("")
  finalizacion     String   @default("")
  portada          String?
  imagenes         Json     @default("[]")
  imagenesAntes    Json     @default("[]") @map("imagenes_antes")
  imagenesProceso  Json     @default("[]") @map("imagenes_proceso")
  imagenesFinal    Json     @default("[]") @map("imagenes_final")
  video            String?
  videos           Json     @default("[]")
  galeriaVideo     Json     @default("[]") @map("galeria_video")
  sucursales       Json     @default("[]")
  stages           Json     @default("[]")
  puntos           Json     @default("[]")
  destacado        Boolean  @default(false)
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("obras")
  @@schema("public")
}

model Trabajo {
  id               String   @id
  slug             String   @unique
  nombre           String
  titulo           String?
  tipo             String?
  categoria        String?
  direccion        String?
  ubicacion        String?
  anio             String?
  descripcion      String   @default("")
  portada          String?
  imagenes         Json     @default("[]")
  imagenesAntes    Json     @default("[]") @map("imagenes_antes")
  imagenesProceso  Json     @default("[]") @map("imagenes_proceso")
  imagenesFinal    Json     @default("[]") @map("imagenes_final")
  video            String?
  videos           Json     @default("[]")
  galeriaVideo     Json     @default("[]") @map("galeria_video")
  secciones        Json     @default("[]")
  stages           Json     @default("[]")
  puntos           Json     @default("[]")
  destacado        Boolean  @default(false)
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("trabajos")
  @@schema("public")
}

model Evento {
  id               String   @id
  slug             String   @unique
  nombre           String
  titulo           String?
  tipo             String?
  categoria        String?
  direccion        String?
  ubicacion        String?
  anio             String?
  descripcion      String   @default("")
  portada          String?
  imagenes         Json     @default("[]")
  imagenesAntes    Json     @default("[]") @map("imagenes_antes")
  imagenesProceso  Json     @default("[]") @map("imagenes_proceso")
  imagenesFinal    Json     @default("[]") @map("imagenes_final")
  video            String?
  videos           Json     @default("[]")
  galeriaVideo     Json     @default("[]") @map("galeria_video")
  secciones        Json     @default("[]")
  stages           Json     @default("[]")
  puntos           Json     @default("[]")
  destacado        Boolean  @default(false)
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("eventos")
  @@schema("public")
}

model Contacto {
  id           String    @id @default(cuid())
  nombre       String
  telefono     String
  email        String?
  mensaje      String
  estado       String    @default("nuevo")
  respondida   Boolean   @default(false)
  respondidaAt DateTime? @map("respondida_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("contactos")
  @@schema("public")
}

model LoginLog {
  id        String   @id @default(cuid())
  email     String
  success   Boolean  @default(false)
  reason    String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("login_logs")
  @@schema("public")
}

model SiteSetting {
  id        String   @id
  data      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
  @@schema("public")
}

model Profile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admin_profiles")
  @@schema("public")
}

model Category {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String   @unique
  name         String
  description  String   @default("")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  works        Work[]

  @@map("categories")
  @@schema("public")
}

model Work {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String      @unique
  title        String
  summary      String      @default("") @map("short_description")
  body         String      @default("") @map("description")
  client       String?     @map("client_name")
  location     String?
  address      String?
  status       String      @default("draft")
  coverImageUrl  String?   @map("cover_image_url")
  coverImagePath String?   @map("cover_image_path")
  displayOrder Int         @default(0) @map("sort_order")
  isFeatured   Boolean     @default(false) @map("featured")
  categoryId   String?     @map("category_id") @db.Uuid
  authorId     String?     @map("created_by") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at")
  category     Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images       WorkImage[]

  @@map("works")
  @@schema("public")
}

model WorkImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workId    String   @map("work_id") @db.Uuid
  imageUrl  String   @map("image_url")
  imagePath String   @map("image_path")
  alt       String   @default("")
  section   String   @default("gallery") @map("stage")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@map("work_images")
  @@schema("public")
}

model SiteText {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  title       String?
  value       String   @default("") @map("content") @db.Text
  section     String   @default("general")
  description String   @default("")
  extra       Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_texts")
  @@schema("public")
}
