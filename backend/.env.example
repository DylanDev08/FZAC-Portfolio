# Server
NODE_ENV=development
# Render inyecta PORT automaticamente. Este valor es solo para desarrollo local.
PORT=4000
# En Render, el Blueprint inyecta la URL publica exacta del frontend.
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
# Dominios personalizados adicionales, separados por comas.
ADDITIONAL_CORS_ORIGINS=

# Database - Prisma + Supabase
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[DB_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase Auth
ADMIN_EMAILS=[ADMIN_EMAIL_1],[ADMIN_EMAIL_2]

# Supabase SDK
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
SUPABASE_STORAGE_BUCKET=crud-images
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,image/avif,image/heic,image/heif,image/heic-sequence,image/heif-sequence,image/bmp,image/x-ms-bmp,image/tiff,image/x-tiff

# Seguridad
JSON_LIMIT=2mb
RATE_LIMIT_MAX=100
ADMIN_RATE_LIMIT_MAX=120
